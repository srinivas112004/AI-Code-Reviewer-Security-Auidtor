# ─── AI Code Reviewer & Security Auditor ───
# Copy this file to .env and fill in your values

# Google Gemini API Key (required)
GOOGLE_API_KEY=your_google_api_key_here

# Flask Secret Key (optional, auto-generated if not set)
# SECRET_KEY=your_secret_key_here

# ─── SMTP Email Configuration (required for OTP emails) ───
# For Gmail: Use smtp.gmail.com with an App Password
#   1. Enable 2-Step Verification at https://myaccount.google.com/security
#   2. Create App Password at https://myaccount.google.com/apppasswords
#   3. Use the 16-char app password as SMTP_PASSWORD

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_FROM_NAME=AI Code Reviewer
SMTP_USE_TLS=true
